{
  "postgres": {
    "password": "DATABASE_PASSWORD"
  },
  "mode": "NODE_ENV",
  "workflow_server": {
    "base_url": "WORKFLOW_SERVER_BASE_URL",
    "auth_token": "WORKFLOW_AUTH_TOKEN"
  },
  "oauth": {
    "base_url": "OAUTH_BASE_URL",
    "download": {
      "client_id": "OAUTH_DOWNLOAD_CLIENT_ID",
      "client_secret": "OAUTH_DOWNLOAD_CLIENT_SECRET"
    },
    "upload": {
      "client_id": "OAUTH_UPLOAD_CLIENT_ID",
      "client_secret": "OAUTH_UPLOAD_CLIENT_SECRET"
    }
  },
  "auth": {
    "google": {
      "client_id": "GOOGLE_OAUTH_CLIENT_ID",
      "client_secret": "GOOGLE_OAUTH_CLIENT_SECRET"
    },
    "cilogon": {
      "client_id": "CILOGON_OAUTH_CLIENT_ID",
      "client_secret": "CILOGON_OAUTH_CLIENT_SECRET"
    },
    "microsoft": {
      "client_id": "MICROSOFT_OAUTH_CLIENT_ID",
      "client_secret": "MICROSOFT_OAUTH_CLIENT_SECRET"
    }
  },
  "download_server": {
    "base_url": "DOWNLOAD_SERVER_BASE_URL"
  },
  "upload": {
    "path": "UPLOAD_DIR"
  },
  "e2e": {
    "users": {
      "admin": {
        "username": "E2E_ADMIN"
      },
      "operator": {
        "username": "E2E_OPERATOR"
      },
      "user": {
        "username": "E2E_USER"
      }
    }
  },
  "filesystem": {
    "search_spaces": "FILESYSTEM_SEARCH_SPACES",
    "base_dir": {
      "slateScratch": "FILESYSTEM_BASE_DIR_SCRATCH"
    },
    "mount_dir": {
      "slateScratch": "FILESYSTEM_MOUNT_DIR_SCRATCH"
    }
  },
  "restricted_import_dirs": {
    "slateScratch": "SCRATCH_IMPORT_RESTRICTED_DIRS"
  },
  "redis": {
    "host": "REDIS_HOST",
    "port": "REDIS_PORT",
    "password": "REDIS_PASSWORD"
  },
  "smtp": {
    "host": "SMTP_HOST",
    "port": "SMTP_PORT",
    "secure": "SMTP_SECURE",
    "auth": {
      "user": "SMTP_AUTH_USER",
      "pass": "SMTP_AUTH_PASS"
    }
  }
}