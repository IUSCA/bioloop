<!-- Workflow Update Notification -->
<mj-section background-color="#ffffff" padding="28px 24px 36px">
  <mj-column>
    <mj-text font-size="22px" font-weight="700" color="#1a202c" line-height="1.3"
             padding="0 0 8px 0">
      {{workflowName}}
    </mj-text>
    <mj-text font-size="13px" color="#718096" padding="0 0 20px 0">
      Step: {{stepName}} &nbsp;&middot;&nbsp; Status: <strong>{{status}}</strong>
    </mj-text>
    <mj-text font-size="14px" color="#4a5568" line-height="1.7"
             padding="0{{#if actionUrl}} 0 28px{{/if}}">
      {{message}}
    </mj-text>
    {{#if actionUrl}}
    <mj-button href="{{actionUrl}}">
      {{#if actionLabel}}{{actionLabel}}{{else}}View Workflow{{/if}}
    </mj-button>
    {{/if}}
  </mj-column>
</mj-section>