<!-- Alert Notification -->
{{#ifEq severity "critical"}}
<mj-section background-color="#ffffff" padding="28px 24px 0">
  <mj-column>
    <mj-text background-color="#fef2f2" border-left="4px solid #dc2626"
             padding="10px 14px" font-size="13px" font-weight="700" color="#dc2626">
      &#9888;&nbsp; CRITICAL ALERT
    </mj-text>
  </mj-column>
</mj-section>
{{/ifEq}}

<mj-section background-color="#ffffff" padding="28px 24px 36px">
  <mj-column>
    <mj-text font-size="22px" font-weight="700" color="#1a202c" line-height="1.3"
             padding="0 0 16px 0">
      {{alertTitle}}
    </mj-text>
    <mj-text font-size="14px" color="#4a5568" line-height="1.7"
             padding="0{{#if actionUrl}} 0 28px{{/if}}">
      {{alertBody}}
    </mj-text>
    {{#if actionUrl}}
    <mj-button href="{{actionUrl}}">
      {{#if actionLabel}}{{actionLabel}}{{else}}View Details{{/if}}
    </mj-button>
    {{/if}}
  </mj-column>
</mj-section>