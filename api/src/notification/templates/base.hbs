<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
  "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="x-apple-disable-message-reformatting">
  <title>{{subject}}</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  <style type="text/css">
    /* Only put resets and media queries here.
       Everything else must be inlined. */
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; }
    
    /* Mobile responsive */
    @media only screen and (max-width: 600px) {
      .wrapper { width: 100% !important; }
      .content-td { padding: 20px !important; }
    }
  </style>
</head>
<body style="margin:0; padding:0; background-color:#f4f6f9;">

  <!-- Outer wrapper table — centers the email -->
  <table role="presentation" border="0" cellpadding="0" cellspacing="0"
         width="100%" style="background-color:#f4f6f9;">
    <tr>
      <td align="center" style="padding: 32px 16px;">

        <!-- Email card — fixed 600px width -->
        <table role="presentation" border="0" cellpadding="0" cellspacing="0"
               width="600" class="wrapper"
               style="background-color:#ffffff; border-radius:8px;
                      box-shadow: 0 2px 8px rgba(0,0,0,0.08);">

          <!-- HEADER -->
          <tr>
            <td style="background-color:#1a2744; border-radius:8px 8px 0 0;
                        padding: 24px 32px;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td>
                    <p style="margin:0; font-family: Arial, sans-serif;
                               font-size:18px; font-weight:bold;
                               color:#ffffff; line-height:1.3;">
                      University System
                    </p>
                    <p style="margin:4px 0 0; font-family: Arial, sans-serif;
                               font-size:12px; color:#8fa3c8; line-height:1;">
                      {{_meta.type}} &middot; {{formatDate _meta.generatedAt}}
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- BODY (injected by child templates) -->
          <tr>
            <td class="content-td" style="padding: 32px; font-family: Arial, sans-serif;
                         font-size:14px; color:#2d3748; line-height:1.6;">
              {{{body}}}
            </td>
          </tr>

          <!-- DIVIDER -->
          <tr>
            <td style="padding: 0 32px;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td style="border-top: 1px solid #e2e8f0; font-size:0; line-height:0;">&nbsp;</td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="padding: 20px 32px; background-color:#f8fafc;
                        border-radius: 0 0 8px 8px;">
              <p style="margin:0; font-family: Arial, sans-serif;
                         font-size:11px; color:#94a3b8; text-align:center; line-height:1.5;">
                This is an automated message. Please do not reply to this email.<br>
                &copy; {{year}} University. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
        <!-- /email card -->

      </td>
    </tr>
  </table>

</body>
</html>