<!-- Request Notification -->
<mj-section background-color="#ffffff" padding="28px 24px 36px">
  <mj-column>
    <mj-text font-size="22px" font-weight="700" color="#1a202c" line-height="1.3"
             padding="0 0 8px 0">
      {{requestTitle}}
    </mj-text>
    <mj-text font-size="13px" color="#718096" padding="0 0 20px 0">
      {{requestType}} &nbsp;&middot;&nbsp; Requested by {{requesterName}}
    </mj-text>
    <mj-text font-size="14px" color="#4a5568" line-height="1.7"
             padding="0 0 {{#if dueDate}}16px{{else}}{{#if actionUrl}}28px{{else}}0{{/if}}{{/if}} 0">
      {{message}}
    </mj-text>
    {{#if dueDate}}
    <mj-text font-size="13px" color="#92400e" background-color="#fffbeb"
             padding="8px 12px {{#if actionUrl}}16px{{else}}0{{/if}} 12px">
      &#x23F0;&nbsp; Due: {{formatDate dueDate}}
    </mj-text>
    {{/if}}
    {{#if actionUrl}}
    <mj-button href="{{actionUrl}}" padding="28px 0 0 0">
      {{#if actionLabel}}{{actionLabel}}{{else}}View Request{{/if}}
    </mj-button>
    {{/if}}
  </mj-column>
</mj-section>