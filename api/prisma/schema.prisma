generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["strictUndefinedChecks", "views"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model dataset {
  id                Int      @id @default(autoincrement())
  name              String
  type              String
  num_directories   Int?
  num_files         Int?
  du_size           BigInt?
  size              BigInt?
  bundle_size       BigInt?
  description       String?
  created_at        DateTime @default(now()) @db.Timestamp(6)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamp(6)
  origin_path       String?
  archive_path      String?
  staged_path       String?
  is_deleted        Boolean  @default(false)
  is_staged         Boolean  @default(false)
  metadata          Json?
  src_instrument_id Int?
  owner_group_id    String?

  workflows        workflow[]
  files            dataset_file[]
  audit_logs       dataset_audit[]
  states           dataset_state[]
  derived_datasets dataset_hierarchy[] @relation("source_datasets")
  source_datasets  dataset_hierarchy[] @relation("derived_datasets")
  projects         project_dataset[]
  accesses         data_access_log[]
  stage_requests   stage_request_log[]
  bundle           bundle?
  src_instrument   instrument?         @relation(fields: [src_instrument_id], references: [id])

  owner_group   group?                      @relation(fields: [owner_group_id], references: [id], onDelete: Restrict)
  collections   collection_dataset[]
  contributions user_dataset_contribution[]
  resource_id   String                     @unique
  // Restrict: prevents deleting a resource row directly while this dataset still references it.
  // Reverse cascade (dataset deleted → resource deleted) is enforced via a DB trigger:
  //   AFTER DELETE ON "dataset" FOR EACH ROW: IF resource_id IS NOT NULL THEN DELETE FROM resource WHERE id = OLD.resource_id
  resource      resource                   @relation(fields: [resource_id], references: [id], onDelete: Restrict)

  @@unique([name, type, is_deleted])
}

model dataset_hierarchy {
  source_id       Int
  derived_id      Int
  assigned_at     DateTime @default(now()) @db.Timestamp(6)
  source_dataset  dataset  @relation(name: "source_datasets", fields: [source_id], references: [id], onDelete: Cascade)
  derived_dataset dataset  @relation(name: "derived_datasets", fields: [derived_id], references: [id], onDelete: Cascade)

  @@id([source_id, derived_id])
}

model dataset_file {
  id         Int                      @id @default(autoincrement())
  name       String?
  path       String
  md5        String?
  size       BigInt?
  filetype   String?
  metadata   Json?
  status     String?
  dataset_id Int
  dataset    dataset                  @relation(fields: [dataset_id], references: [id], onDelete: Cascade)
  parents    dataset_file_hierarchy[] @relation("child")
  children   dataset_file_hierarchy[] @relation("parent")
  accesses   data_access_log[]

  @@unique([path, dataset_id])
  @@index([dataset_id])
}

model dataset_file_hierarchy {
  parent_id Int
  child_id  Int
  parent    dataset_file? @relation(name: "parent", fields: [parent_id], references: [id], onDelete: Cascade)
  child     dataset_file? @relation(name: "child", fields: [child_id], references: [id], onDelete: Cascade)

  @@id([parent_id, child_id])
  @@index([child_id])
}

model dataset_upload_log {
  id           Int               @id @default(autoincrement())
  status       upload_status
  files        file_upload_log[]
  updated_at   DateTime          @default(now()) @updatedAt @db.Timestamp(6)
  audit_log    dataset_audit     @relation(fields: [audit_log_id], references: [id], onDelete: Cascade)
  audit_log_id Int               @unique
}

model file_upload_log {
  id                    Int                 @id @default(autoincrement())
  name                  String
  md5                   String
  num_chunks            Int
  status                upload_status
  path                  String?
  dataset_upload_log    dataset_upload_log? @relation(fields: [dataset_upload_log_id], references: [id], onDelete: Cascade)
  dataset_upload_log_id Int?
}

model dataset_audit {
  id            Int                    @id @default(autoincrement())
  action        String
  create_method DATASET_CREATE_METHOD?
  updated_at    DateTime               @default(now()) @updatedAt @db.Timestamp(6)
  timestamp     DateTime               @default(now())
  old_data      Json?
  new_data      Json?
  user_id       Int?
  user          user?                  @relation(fields: [user_id], references: [id], onDelete: SetNull)
  dataset_id    Int?
  dataset       dataset?               @relation(fields: [dataset_id], references: [id], onDelete: Cascade)
  upload        dataset_upload_log?

  @@unique([dataset_id, create_method])
}

model dataset_state {
  state      String
  timestamp  DateTime @default(now()) @db.Timestamp(6)
  metadata   Json?
  dataset_id Int
  dataset    dataset? @relation(fields: [dataset_id], references: [id], onDelete: Cascade)

  @@id([timestamp, dataset_id, state])
}

model bundle {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamp(6)
  name       String
  size       BigInt?
  md5        String
  dataset_id Int      @unique
  dataset    dataset  @relation(fields: [dataset_id], references: [id], onDelete: Cascade)
}

model data_access_log {
  id           Int           @id @default(autoincrement())
  timestamp    DateTime      @default(now()) @db.Timestamp(6)
  access_type  access_type
  file_id      Int?
  dataset_file dataset_file? @relation(fields: [file_id], references: [id])
  dataset_id   Int?
  dataset      dataset?      @relation(fields: [dataset_id], references: [id])
  user_id      Int?
  user         user?         @relation(fields: [user_id], references: [id], onDelete: SetNull)
}

model stage_request_log {
  id         Int      @id @default(autoincrement())
  timestamp  DateTime @default(now()) @db.Timestamp(6)
  dataset_id Int?
  dataset    dataset? @relation(fields: [dataset_id], references: [id])
  user_id    Int?
  user       user?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
}

model user {
  id                         Int                 @id @default(autoincrement())
  username                   String              @unique @db.VarChar(100)
  name                       String?             @db.VarChar(100)
  email                      String              @unique @db.VarChar(100)
  cas_id                     String?             @unique @db.VarChar(100)
  notes                      String?
  created_at                 DateTime            @default(now()) @db.Timestamp(6)
  updated_at                 DateTime            @default(now()) @updatedAt @db.Timestamp(6)
  is_deleted                 Boolean             @default(false)
  metadata                   Json?
  user_role                  user_role[]
  settings                   user_settings?
  contacts                   contact[]
  dataset_audit              dataset_audit[]
  projects                   project_user[]      @relation("project_user_user")
  password                   user_password?
  login                      user_login?
  accesses                   data_access_log[]
  stage_requests             stage_request_log[]
  about_edits                about[]
  project_users_assigned     project_user[]      @relation("project_user_assignor")
  project_datasets_assigned  project_dataset[]
  project_contacts_assigned  project_contact[]
  initiated_workflows        workflow[]          @relation("initiated_workflows")
  acknowledged_notifications notification[]
  user_notifications         user_notification[]
  owned_projects             project[]
  // created_datasets           dataset_create_log[]
  alerts_created             alert[]

  group_memberships         group_user[]                @relation("user_memberships")
  memberships_assigned      group_user[]                @relation("membership_assignor")
  collection_datasets_added collection_dataset[]        @relation("collection_dataset_adder")
  grants_created            grant[]                     @relation("grants_created")
  grants_revoked            grant[]                     @relation("grants_revoked")
  access_requests           access_request[]            @relation("access_requests_created")
  access_requests_reviewed  access_request[]            @relation("access_requests_reviewed")
  authorization_audits      authorization_audit[]
  contributions             user_dataset_contribution[]
  subject_id                String                     @unique
  // Restrict: prevents deleting a subject row directly while this user still references it.
  // Reverse cascade (user deleted → subject deleted) is enforced via a DB trigger:
  //   AFTER DELETE ON "user" FOR EACH ROW: DELETE FROM subject WHERE id = OLD.subject_id
  subject                   subject                    @relation(fields: [subject_id], references: [id], onDelete: Restrict)
}

model user_password {
  id         Int      @id @default(autoincrement())
  password   String   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(6)
  user_id    Int      @unique
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model user_login {
  id         Int      @id @default(autoincrement())
  last_login DateTime @default(now()) @db.Timestamp(6)
  method     String
  user_id    Int      @unique
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model user_settings {
  id       Int  @id @default(autoincrement())
  user_id  Int  @unique
  settings Json
  users    user @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model notification {
  id                 Int                 @id @default(autoincrement())
  created_at         DateTime            @default(now()) @db.Timestamp(6)
  label              String
  text               String?
  status             NOTIFICATION_STATUS @default(CREATED)
  acknowledged_by_id Int?
  acknowledged_by    user?               @relation(fields: [acknowledged_by_id], references: [id], onDelete: Cascade)
  role_notifications role_notification[]
  user_notifications user_notification[]
}

model role_notification {
  id              Int          @id @default(autoincrement())
  role_id         Int
  role            role         @relation(fields: [role_id], references: [id])
  notification_id Int
  notification    notification @relation(fields: [notification_id], references: [id], onDelete: Cascade)

  @@unique([notification_id, role_id])
}

model user_notification {
  id              Int          @id @default(autoincrement())
  user_id         Int
  user            user         @relation(fields: [user_id], references: [id])
  notification_id Int
  notification    notification @relation(fields: [notification_id], references: [id], onDelete: Cascade)

  @@unique([notification_id, user_id])
}

model contact {
  id          Int               @id @default(autoincrement())
  type        String
  value       String
  description String?
  user_id     Int?
  user        user?             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  projects    project_contact[]

  @@unique([type, value])
}

model role {
  id                 Int                 @id @default(autoincrement())
  name               String              @db.VarChar(50)
  description        String              @default("") @db.VarChar(255)
  user_role          user_role[]
  role_notifications role_notification[]
}

model user_role {
  user_id     Int
  role_id     Int
  roles       role     @relation(fields: [role_id], references: [id], onDelete: Cascade)
  users       user     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assigned_at DateTime @default(now())

  @@id([user_id, role_id])
}

model workflow {
  id           String   @id
  dataset_id   Int?
  dataset      dataset? @relation(fields: [dataset_id], references: [id], onDelete: Cascade)
  initiator_id Int?
  initiator    user?    @relation("initiated_workflows", fields: [initiator_id], references: [id], onDelete: SetNull)
}

model metric {
  timestamp   DateTime @default(now()) @db.Timestamp(6)
  measurement String
  subject     String
  usage       BigInt?
  limit       BigInt?
  fields      Json?
  tags        Json?

  @@id([timestamp, measurement, subject])
}

model project {
  id              String            @id @default(uuid())
  slug            String            @unique
  name            String
  description     String?
  browser_enabled Boolean           @default(false)
  funding         String?
  metadata        Json?
  created_at      DateTime          @default(now()) @db.Timestamp(6)
  updated_at      DateTime          @default(now()) @updatedAt @db.Timestamp(6)
  owner_id        Int?
  owner           user?             @relation(fields: [owner_id], references: [id], onDelete: SetNull)
  users           project_user[]
  datasets        project_dataset[]
  contacts        project_contact[]
}

model project_user {
  project_id  String
  user_id     Int
  assigned_at DateTime @default(now()) @db.Timestamp(6)
  assignor_id Int?
  project     project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user        user     @relation(fields: [user_id], references: [id], onDelete: Cascade, name: "project_user_user")
  assignor    user?    @relation(fields: [assignor_id], references: [id], onDelete: SetNull, name: "project_user_assignor")

  @@id([project_id, user_id])
}

model project_dataset {
  project_id  String
  dataset_id  Int
  assignor_id Int?
  assigned_at DateTime @default(now()) @db.Timestamp(6)
  project     project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  dataset     dataset  @relation(fields: [dataset_id], references: [id], onDelete: Cascade)
  assignor    user?    @relation(fields: [assignor_id], references: [id], onDelete: SetNull)

  @@id([project_id, dataset_id])
}

model project_contact {
  project_id  String
  contact_id  Int
  assigned_at DateTime @default(now()) @db.Timestamp(6)
  assignor_id Int?
  project     project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  contact     contact  @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  assignor    user?    @relation(fields: [assignor_id], references: [id], onDelete: SetNull)

  @@id([project_id, contact_id])
}

model log {
  id                Int            @id @default(autoincrement())
  timestamp         DateTime       @default(now()) @db.Timestamp(6)
  message           String
  level             String
  worker_process_id Int
  worker_log        worker_process @relation(fields: [worker_process_id], references: [id], onDelete: Cascade)

  @@index([worker_process_id])
}

model worker_process {
  id          Int      @id @default(autoincrement())
  pid         Int
  task_id     String
  step        String
  workflow_id String
  tags        Json?
  start_time  DateTime @default(now()) @db.Timestamp(6)
  hostname    String
  logs        log[]
}

model about {
  id                 Int      @id @default(autoincrement())
  html               String
  created_at         DateTime @default(now()) @db.Timestamp(6)
  last_updated_by    user?    @relation(fields: [last_updated_by_id], references: [id], onDelete: SetNull)
  last_updated_by_id Int?
}

model nonce {
  id         String    @id @default(uuid())
  created_at DateTime  @default(now()) @db.Timestamp(6)
  purpose    String?
  expires_at DateTime?
}

model instrument {
  id               Int       @id @default(autoincrement())
  name             String    @unique
  host             String    @unique
  description      String?
  created_at       DateTime  @default(now()) @db.Timestamp(6)
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  sourced_datasets dataset[]
}

model alert {
  id            Int        @id @default(autoincrement())
  created_at    DateTime   @default(now()) @db.Timestamp(6)
  updated_at    DateTime   @default(now()) @updatedAt @db.Timestamp(6)
  created_by_id Int?
  created_by    user?      @relation(fields: [created_by_id], references: [id], onDelete: SetNull)
  label         String?
  message       String?
  type          ALERT_TYPE
  start_time    DateTime?  @db.Timestamp(6)
  end_time      DateTime?  @db.Timestamp(6)
  is_hidden     Boolean?   @default(false)
}

// ============================================================================
// Hierarchical Groups, Collections, and Data Access Control Models
// ============================================================================

// ============================================================================
// RESOURCE / SUBJECT - Common parent tables for real FK integrity
// ============================================================================

enum RESOURCE_TYPE {
  DATASET
  COLLECTION
}

enum SUBJECT_TYPE {
  USER
  GROUP
}

model resource {
  id   String        @id @default(uuid())
  type RESOURCE_TYPE

  dataset         dataset?
  collection      collection?
  grants          grant[]
  access_requests access_request[]
}

model subject {
  id   String       @id @default(uuid())
  type SUBJECT_TYPE

  user   user?
  group  group?
  grants grant[]
}

// created everyone group and added rules to protect modification in migration script
model group {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?

  // Lifecycle
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  updated_at  DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  archived_at DateTime? @db.Timestamp(6)
  is_archived Boolean   @default(false)
  version     Int       @default(1) // For optimistic concurrency control

  // Settings
  allow_user_contributions Boolean @default(false)
  metadata                 Json?

  // Relations
  members           group_user[]
  ancestor_edges    group_closure[]             @relation("group_ancestors")
  descendant_edges  group_closure[]             @relation("group_descendants")
  owned_datasets    dataset[]
  owned_collections collection[]
  contributions     user_dataset_contribution[]
  // Restrict: prevents deleting a subject row directly while this group still references it.
  // Reverse cascade (group deleted → subject deleted) is enforced via a DB trigger:
  //   AFTER DELETE ON "group" FOR EACH ROW: DELETE FROM subject WHERE id = OLD.id
  subject           subject                     @relation(fields: [id], references: [id], onDelete: Restrict)
}

// Closure table for efficient hierarchy traversal
model group_closure {
  ancestor_id   String
  descendant_id String
  depth         Int

  ancestor   group @relation("group_ancestors", fields: [ancestor_id], references: [id], onDelete: Cascade)
  descendant group @relation("group_descendants", fields: [descendant_id], references: [id], onDelete: Cascade)

  @@id([ancestor_id, descendant_id])
  @@index([descendant_id, depth])
  @@index([ancestor_id, depth])
}

// Group membership with roles
model group_user {
  group_id    String
  user_id     String
  role        GROUP_MEMBER_ROLE @default(MEMBER)
  assigned_at DateTime          @default(now()) @db.Timestamp(6)
  assigned_by String?

  group    group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user     user  @relation("user_memberships", fields: [user_id], references: [subject_id], onDelete: Cascade)
  assignor user? @relation("membership_assignor", fields: [assigned_by], references: [subject_id], onDelete: SetNull)

  @@id([group_id, user_id])
  @@index([user_id])
}

enum GROUP_MEMBER_ROLE {
  MEMBER
  ADMIN
}

model user_dataset_contribution {
  id         Int      @id @default(autoincrement())
  group_id   String
  user_id    String
  dataset_id String
  created_at DateTime @default(now()) @db.Timestamp(6)

  group   group   @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user    user    @relation(fields: [user_id], references: [subject_id], onDelete: Cascade)
  dataset dataset @relation(fields: [dataset_id], references: [resource_id], onDelete: Cascade)

  @@unique([group_id, user_id, dataset_id])
  @@index([group_id])
  @@index([user_id])
  @@index([dataset_id])
}

// ============================================================================
// COLLECTIONS - Authorization containers for datasets
// ============================================================================

model collection {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  version     Int     @default(1) // For optimistic concurrency control

  // Ownership (single owning group)
  owner_group_id String
  owner_group    group  @relation(fields: [owner_group_id], references: [id], onDelete: Restrict)

  // Lifecycle
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  updated_at  DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  archived_at DateTime? @db.Timestamp(6)
  is_archived Boolean   @default(false)

  // Settings
  metadata Json?

  // Relations
  datasets collection_dataset[]
  // Restrict: prevents deleting a resource row directly while this collection still references it.
  // Reverse cascade (collection deleted → resource deleted) is enforced via a DB trigger:
  //   AFTER DELETE ON "collection" FOR EACH ROW: DELETE FROM resource WHERE id = OLD.id
  resource resource             @relation(fields: [id], references: [id], onDelete: Restrict)

  @@index([owner_group_id])
  @@index([is_archived])
}

model collection_dataset {
  collection_id String
  dataset_id    String
  added_at      DateTime @default(now()) @db.Timestamp(6)
  added_by      String?

  collection collection @relation(fields: [collection_id], references: [id], onDelete: Cascade)
  dataset    dataset    @relation(fields: [dataset_id], references: [resource_id], onDelete: Cascade)
  adder      user?      @relation("collection_dataset_adder", fields: [added_by], references: [subject_id], onDelete: SetNull)

  @@id([collection_id, dataset_id])
  @@index([dataset_id])
}

// ============================================================================
// GRANTS - Durable authorization facts
//
// Has an exclusion constraint to prevent overlapping grants. Defined in the migration script.
// For the same (subject_type, subject_id, resource_type, resource_id, access_type_id) tuple, 
// there must never exist two non-revoked grants whose validity intervals overlap.
// ============================================================================

model grant {
  id String @id @default(uuid())

  // Subject (who receives access)
  subject_id String
  subject    subject @relation(fields: [subject_id], references: [id], onDelete: Restrict)

  // Resource (what is being accessed)
  resource_id String
  resource    resource @relation(fields: [resource_id], references: [id], onDelete: Restrict)

  // Access type (what action is allowed) - atomic granularity by design
  access_type_id Int
  access_type    grant_access_type @relation(fields: [access_type_id], references: [id], onDelete: Restrict)

  // Temporal bounds
  valid_from   DateTime                @default(now()) @db.Timestamp(6)
  valid_until  DateTime?               @db.Timestamp(6)
  valid_period Unsupported("tsrange")? @default(dbgenerated("tsrange(valid_from, valid_until, '[)'::text)"))
  // valid_period is a generated column defined in the migration SQL to leverage PostgreSQL's range types for efficient overlap checks
  // https://github.com/prisma/prisma/discussions/24880#discussioncomment-15783547
  // I had to 1. create migration, 2. apply it, 3. npx prisma db pull, 4. copy the generated column definition from the schema.prisma
  // 4. git reset --hard, 5. paste the generated column definition back into schema.prisma, 6. commit the changes. 
  // Otherwise, Prisma would try to drop and recreate the column on every migration since it doesn't recognize it as a generated column.

  // Provenance
  granted_by    String
  justification String? // Optional justification for the grant creation or revocation
  created_at    DateTime            @default(now()) @db.Timestamp(6)
  revoked_at    DateTime?           @db.Timestamp(6)
  revoked_by    String?
  creation_type GRANT_CREATION_TYPE // How was this grant created (manual admin action, system bootstrap, access request approval, etc.)

  // Relations
  grantor user  @relation("grants_created", fields: [granted_by], references: [subject_id], onDelete: Restrict)
  revoker user? @relation("grants_revoked", fields: [revoked_by], references: [subject_id], onDelete: SetNull)

  // If created via access request approval, link back to the request item that led to this grant
  accessRequestItems access_request_item[]

  // valid_period generated column and grant_no_overlap exclusion constraint are defined in the migration SQL
  // For the same (subject_id, resource_id, access_type_id) tuple,
  // there must never exist two non-revoked grants whose validity intervals overlap.

  @@index([subject_id])
  @@index([resource_id])
  @@index([valid_from, valid_until])
}

enum GRANT_CREATION_TYPE {
  ACCESS_REQUEST
  MANUAL
  SYSTEM_BOOTSTRAP
}

model grant_access_type {
  id            Int                 @id @default(autoincrement())
  name          String
  description   String?

  grants             grant[]
  accessRequestItems access_request_item[]

  @@unique([name])
}

// ============================================================================
// ACCESS REQUESTS - Workflow objects (not authorization primitives)
// ============================================================================

model access_request {
  id String @id @default(uuid())

  // Request type
  type ACCESS_REQUEST_TYPE

  // Target resource
  resource_id String
  resource    resource @relation(fields: [resource_id], references: [id], onDelete: Cascade)

  // Requester
  requester_id String
  requester    user @relation("access_requests_created", fields: [requester_id], references: [subject_id], onDelete: Restrict)

  // Justification
  purpose String?

  // Prior context (for renewals)
  previous_grant_ids String[] // References expired grants

  // Status
  status ACCESS_REQUEST_STATUS @default(DRAFT)

  // Review
  reviewed_by     String?
  reviewed_at     DateTime? @db.Timestamp(6)
  decision_reason String?

  // Lifecycle
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  submitted_at DateTime? @db.Timestamp(6)
  closed_at    DateTime? @db.Timestamp(6)

  // Relations
  reviewer user? @relation("access_requests_reviewed", fields: [reviewed_by], references: [subject_id], onDelete: SetNull)

  access_request_items access_request_item[]

  @@index([requester_id, status])
  @@index([resource_id, status])
  @@index([status, submitted_at])
}

model access_request_item {
  id                String                       @id @default(uuid())
  access_request_id String
  access_type_id    Int // What was requested
  requested_until   DateTime?
  decision          ACCESS_REQUEST_ITEM_DECISION @default(PENDING) // Review outcome
  created_grant_id  String?

  access_request access_request    @relation(fields: [access_request_id], references: [id], onDelete: Cascade)
  access_type    grant_access_type @relation(fields: [access_type_id], references: [id], onDelete: Restrict)
  created_grant  grant?            @relation(fields: [created_grant_id], references: [id], onDelete: SetNull)

  // Prevent Duplicate Items Inside Same Request
  @@unique([access_request_id, access_type_id])
}

enum ACCESS_REQUEST_TYPE {
  NEW
  RENEWAL
}

enum ACCESS_REQUEST_STATUS {
  DRAFT
  UNDER_REVIEW
  PARTIALLY_APPROVED
  APPROVED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum ACCESS_REQUEST_ITEM_DECISION {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================================
// AUDIT LOG - Authorization events
// ============================================================================

// partitioned by timestamp in the migration
// monthly partitions named like authorization_audit_2026_01, authorization_audit_2026_02, etc.
model authorization_audit {
  id        Int      @default(autoincrement())
  timestamp DateTime @default(now()) @db.Timestamp(6)

  // Event type
  event_type String

  // Actor
  actor_id String?
  actor    user? @relation(fields: [actor_id], references: [subject_id], onDelete: SetNull)

  // Target
  target_type String // 'user', 'group', 'dataset', 'collection', 'grant'
  target_id   String

  // Details
  action   String? // 'create', 'revoke', 'approve', 'reparent', etc.
  metadata Json?

  // Authorization decision context (for access checks)
  resource_type String?
  resource_id   String?
  decision      Boolean?
  reason        String?

  @@id([id, timestamp]) // include timestamp in primary key to allow partitioning by time
  @@index([event_type, timestamp])
  @@index([actor_id])
  @@index([target_type, target_id])
}

// ============================================================================
// AUTHORITY TRANSFERS - Ownership mutation workflow
// ============================================================================

model authority_transfer {
  id String @id @default(uuid())

  // Generic resource reference
  resource_type AUTH_RESOURCE_TYPE
  resource_id   String

  // Ownership mutation
  source_principal_type PRINCIPAL_TYPE
  source_principal_id   String

  target_principal_type PRINCIPAL_TYPE
  target_principal_id   String

  proposed_by String
  reason      String?

  status AUTH_TRANSFER_STATUS @default(PENDING)

  // Approval tracking
  source_approved_at DateTime?
  source_approved_by String?

  target_approved_at DateTime?
  target_approved_by String?

  executed_at DateTime?
  executed_by String?

  cancelled_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

enum PRINCIPAL_TYPE {
  USER
  GROUP
}

enum AUTH_RESOURCE_TYPE {
  DATASET
  COLLECTION
}

enum AUTH_TRANSFER_STATUS {
  PENDING
  SOURCE_APPROVED
  TARGET_APPROVED
  APPROVED // both sides approved
  EXECUTED
  REJECTED
  CANCELLED
  EXPIRED
}

